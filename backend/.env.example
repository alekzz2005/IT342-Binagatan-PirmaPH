# Environment Configuration
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Production Database URL (for prod profile)
# DATABASE_URL=jdbc:mysql://your-prod-host:3306/pirmaPH_db?useSSL=true&serverTimezone=UTC

# JWT Configuration (use a strong random key - at least 256 bits)
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Production OAuth2 Redirect URI
# OAUTH2_REDIRECT_URI=https://yourdomain.com/login/oauth2/code/google

# Production CORS Origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Server Port (optional, defaults to 8080)
# PORT=8080
