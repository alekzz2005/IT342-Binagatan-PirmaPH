# PirmaPH .gitignore

# ================================
# Backend (Spring Boot / Maven)
# ================================

# Maven
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# Compiled class files
*.class

# Log files
*.log
logs/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# Spring Boot
backend/HELP.md
backend/spring-boot-*.log

# Application properties (sensitive data)
backend/src/main/resources/application-dev.properties
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-local.properties

# ================================
# Frontend (React / Node.js)
# ================================

# Dependencies
web/node_modules/
node_modules/

# Build outputs
web/dist/
web/build/
dist/
build/

# Testing
web/coverage/
coverage/

# Production
web/.vite/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
web/.env
web/.env.local
web/.env.development.local
web/.env.test.local
web/.env.production.local

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Lock files (optional - uncomment if you want to ignore them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# ================================
# Database
# ================================

# Database files
*.db
*.sqlite
*.sqlite3

# MySQL dumps
*.sql
!schema.sql

# ================================
# OS Generated Files
# ================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ================================
# Temporary Files
# ================================

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~.nib
.cache/

# ================================
# Java / IDE Specific
# ================================

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# VS Code
.vscode/
.history/

# ================================
# Documentation Files
# ================================

# Ignore all markdown files except README.md
*.md
!README.md
!readme.md

# Java upgrade workflow (if you use the upgrade agent)
.github/java-upgrade/*/

# ================================
# Security & Secrets
# ================================

# JWT secrets and keys
*.key
*.pem
*.p12
*.jks
secrets/

# ================================
# Docker
# ================================

# Docker environment files
.env.docker
docker-compose.override.yml

# Docker volumes
mysql_data/

# ================================
# Application Logs
# ================================

# Application log directory
logs/
*.log

# ================================
# Backup Files
# ================================

# Backup files
*.bak
*.backup
backup/
credentials/

# API keys
.api-keys
.secrets

# ================================
# Miscellaneous
# ================================

# Layout files (HTML templates)
layout/

# Test files
backend/test-api.http.local
*.http.local

# Package manager
.pnp.*
.yarn/

# Temporarily ignore backend and project documentation files
backend/API_DOCUMENTATION.md
backend/IMPLEMENTATION_SUMMARY.md
backend/SETUP_GUIDE.md
FRONTEND_IMPLEMENTATION.md
GOOGLE_OAUTH_QUICKSTART.md
